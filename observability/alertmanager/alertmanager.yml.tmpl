global:
  smtp_smarthost: '${ALERTMANAGER_SMTP_HOST}:${ALERTMANAGER_SMTP_PORT}'
  smtp_from: '${ALERTMANAGER_EMAIL_FROM}'
  smtp_auth_username: '${ALERTMANAGER_SMTP_USER}'
  smtp_auth_password: '${ALERTMANAGER_SMTP_PASSWORD}'
  smtp_require_tls: ${ALERTMANAGER_SMTP_USE_TLS}

route:
  receiver: warning-grouped
  group_by: ["alertname", "service"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 6h
  routes:
    - matchers:
        - severity="critical"
      receiver: critical-immediate
      group_wait: 0s
      group_interval: 1m
      repeat_interval: 30m

    - matchers:
        - severity="warning"
      receiver: warning-grouped
      group_wait: 2m
      group_interval: 10m
      repeat_interval: 12h

receivers:
  - name: critical-immediate
    email_configs:
      - to: '${ALERTMANAGER_EMAIL_TO}'
        send_resolved: true
        headers:
          Subject: '[CRITICAL][{{ .CommonLabels.service }}] {{ .CommonLabels.alertname }}'

  - name: warning-grouped
    email_configs:
      - to: '${ALERTMANAGER_EMAIL_TO}'
        send_resolved: true
        headers:
          Subject: '[WARNING][{{ .CommonLabels.service }}] {{ .CommonLabels.alertname }}'
