{
  "description": "Operational observability for the transformlivedata pipeline",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "aborted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_finished\" [2m]))",
          "legendFormat": "succeeded",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_aborted\" [2m]))",
          "legendFormat": "aborted",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Executions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_finished\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Completed (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_aborted\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Aborted (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "expectations_validation" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "raw_schema_validation" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "transform" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "save_trusted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "load_positions" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.total_duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "total",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.expectations_validation.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "expectations_validation",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.raw_schema_validation.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "raw_schema_validation",
          "queryType": "range",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.transform.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "transform",
          "queryType": "range",
          "refId": "D"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.save_trusted.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "save_trusted",
          "queryType": "range",
          "refId": "E"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.load_positions.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "load_positions",
          "queryType": "range",
          "refId": "F"
        }
      ],
      "title": "Execution duration (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 0.98 }
            ]
          },
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.record_counts.accepted_records\" | unwrap v [5m])) / avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.record_counts.raw_input_records\" | unwrap v [5m]))",
          "legendFormat": "acceptance rate",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Acceptance rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "raw" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.record_counts.raw_input_records\" | unwrap v [5m]))",
          "legendFormat": "raw",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Raw records",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "invalid_vehicle_ids" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "distance_errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "gx_records_failures" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.transformation_processing_issues.invalid_vehicle_ids_count\" | unwrap v [5m]))",
          "legendFormat": "invalid_vehicle_ids",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.transformation_processing_issues.distance_calculation_errors_count\" | unwrap v [5m]))",
          "legendFormat": "distance_errors",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"quality_report_metrics\" | json v=\"metadata.post_transformation_validation_summary.gx_records_failures\" | unwrap v [5m]))",
          "legendFormat": "gx_records_failures",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Rejected records by reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\" | event=\"execution_aborted\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent failures",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"transformlivedata\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log stream",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["transformlivedata", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
