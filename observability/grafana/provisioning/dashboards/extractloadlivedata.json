{
  "description": "Operational observability for the extractloadlivedata microservice",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "execution_failed_non_recoverable" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "execution_completed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warnings" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (event) (count_over_time({service=\"extractloadlivedata\"} | json | event=~\"execution_completed|execution_failed_non_recoverable\" [5m]))",
          "legendFormat": "{{event}}",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"extractloadlivedata\"} | json | level=\"ERROR\" [5m]))",
          "legendFormat": "errors",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"extractloadlivedata\"} | json | level=\"WARNING\" [5m]))",
          "legendFormat": "warnings",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Executions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"extractloadlivedata\"} | json | level=\"ERROR\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Errors (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"extractloadlivedata\"} | json | level=\"WARNING\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Warnings (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"extractloadlivedata\"} | json | level=\"ERROR\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent failures",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"extractloadlivedata\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log stream",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "extract" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "save" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "notify" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"extractloadlivedata\"} | json | event=\"execution_metrics_final\" | json execution_seconds=\"metadata.execution_seconds\" | unwrap execution_seconds [5m]))",
          "legendFormat": "total",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"extractloadlivedata\"} | json | event=\"execution_metrics_final\" | json extract_duration=\"metadata.phase_durations.extract\" | unwrap extract_duration [5m]))",
          "legendFormat": "extract",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"extractloadlivedata\"} | json | event=\"execution_metrics_final\" | json save_duration=\"metadata.phase_durations.save\" | unwrap save_duration [5m]))",
          "legendFormat": "save",
          "queryType": "range",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"extractloadlivedata\"} | json | event=\"execution_metrics_final\" | json notify_duration=\"metadata.phase_durations.notify\" | unwrap notify_duration [5m]))",
          "legendFormat": "notify",
          "queryType": "range",
          "refId": "D"
        }
      ],
      "title": "Execution time (s)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["extractloadlivedata", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "extractloadlivedata",
  "uid": "extractloadlivedata",
  "version": 101
}
