        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedtripfacts\" | event=\"execution_aborted\" [2m]))",
