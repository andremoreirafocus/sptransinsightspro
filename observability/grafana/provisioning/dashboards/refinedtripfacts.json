        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedtripfacts\" | event=\"execution_finished\" [2m]))",
          "legendFormat": "succeeded",
          "queryType": "range",
          "refId": "A"
