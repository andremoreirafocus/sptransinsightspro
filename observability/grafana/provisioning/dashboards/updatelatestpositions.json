{
  "description": "Operational observability and position freshness for the updatelatestpositions pipeline",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "aborted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_finished\" [2m]))",
          "legendFormat": "succeeded",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_aborted\" [2m]))",
          "legendFormat": "aborted",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Executions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_finished\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Completed (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_aborted\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Aborted (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 6,
            "lineWidth": 0,
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "config_load" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "update_latest_positions" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_phase_metrics\" | json v=\"metadata.total_duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "total",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.config_load.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "config_load",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.update_latest_positions.duration_seconds\" | unwrap v [5m]))",
          "legendFormat": "update_latest_positions",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Phase duration (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "pointSize": 5
          },
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "max(max_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"freshness_evaluation\" | json v=\"metadata.observed_lag_minutes\" | unwrap v [5m]))",
          "legendFormat": "lag_minutes",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Position freshness lag (min)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "records_saved" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"positions_save_succeeded\" | json v=\"metadata.total_records\" | unwrap v [5m]))",
          "legendFormat": "records_saved",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Records saved per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 2, "x": 10, "y": 8 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"updatelatestpositions\" | event=\"positions_update_skipped\" [1h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Skipped runs (last 1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 8,
      "options": {
