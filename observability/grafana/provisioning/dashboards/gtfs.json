{
  "description": "Daily execution history and data volume trends for the gtfs pipeline",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "aborted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_finished\" [1d]))",
          "legendFormat": "succeeded",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_aborted\" [1d]))",
          "legendFormat": "aborted",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Executions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_finished\" [24h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Completed (last 24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_aborted\" [24h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Aborted (last 24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "extract_load_files" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "transformation" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "enrichment" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "quality_report" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.extract_load_files.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "extract_load_files",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.transformation.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "transformation",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.enrichment.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "enrichment",
          "queryType": "range",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.quality_report.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "quality_report",
          "queryType": "range",
          "refId": "D"
        }
      ],
      "title": "Phase duration per run (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "row_count" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"trip_details_creation_succeeded\" | json v=\"metadata.row_count\" | unwrap v [1d]))",
          "legendFormat": "row_count",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Trip details row count per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "file_count" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"gtfs_extraction_succeeded\" | json v=\"metadata.file_count\" | unwrap v [1d]))",
          "legendFormat": "file_count",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "GTFS files extracted per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "validation_errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"raw_file_validation_error\" [1d]))",
          "legendFormat": "validation_errors",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Raw file validation errors per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\" | event=\"execution_aborted\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent aborted executions",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"gtfs\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log stream",
      "type": "logs"
    }
  ],
  "refresh": "1h",
  "schemaVersion": 39,
  "tags": ["gtfs", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "gtfs",
  "uid": "gtfs",
  "version": 1
}
