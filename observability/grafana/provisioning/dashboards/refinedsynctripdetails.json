        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log stream",
      "type": "logs"
    }
  ],
  "refresh": "1h",
  "schemaVersion": 39,
  "tags": ["refinedsynctripdetails", "observability"],
  "templating": {
