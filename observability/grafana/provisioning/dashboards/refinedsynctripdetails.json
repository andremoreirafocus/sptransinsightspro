          "expr": "{service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_aborted\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent aborted executions",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
