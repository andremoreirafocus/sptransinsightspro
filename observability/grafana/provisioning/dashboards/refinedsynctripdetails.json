{
  "description": "Daily execution history and data volume for the refinedsynctripdetails pipeline",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "aborted" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_finished\" [1d]))",
          "legendFormat": "succeeded",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_aborted\" [1d]))",
          "legendFormat": "aborted",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Executions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_finished\" [24h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Completed (last 24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "match": "null", "result": { "text": "0" } }, "type": "special" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 2, "x": 10, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_aborted\" [24h])",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Aborted (last 24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "config_load" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "load_trip_details" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "transform_trip_details" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "save_trip_details" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.config_load.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "config_load",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.load_trip_details.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "load_trip_details",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.transform_trip_details.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "transform_trip_details",
          "queryType": "range",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"execution_phase_metrics\" | json v=\"metadata.phase_metrics.save_trip_details.duration_seconds\" | unwrap v [1d]))",
          "legendFormat": "save_trip_details",
          "queryType": "range",
          "refId": "D"
        }
      ],
      "title": "Phase duration per run (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "records_loaded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"trip_details_load_succeeded\" | json v=\"metadata.record_count\" | unwrap v [1d]))",
          "legendFormat": "records_loaded",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Trip details records loaded per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "records_saved" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(last_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"trip_details_save_succeeded\" | json v=\"metadata.record_count\" | unwrap v [1d]))",
          "legendFormat": "records_saved",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Trip details records saved per run",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "points",
            "pointSize": 8,
            "lineWidth": 0,
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "skipped" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=\"airflow_tasks\"} | json | service_extracted=\"refinedsynctripdetails\" | event=\"trip_details_transform_skipped\" [1d]))",
          "legendFormat": "skipped",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Skipped runs (no trip details to sync)",
