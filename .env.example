# MinIO version
MINIO_VERSION=RELEASE.2025-02-28T09-55-16Z
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_PLATFORM_ACCESS_KEY=
MINIO_PLATFORM_SECRET_KEY=

# Airflow DB credentials
AIRFLOW_DB_USER=
AIRFLOW_DB_PASSWORD=

# Airflow admin bootstrap
AIRFLOW_ADMIN_USERNAME=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_FIRSTNAME=
AIRFLOW_ADMIN_LASTNAME=
AIRFLOW_ADMIN_EMAIL=

# Postgres DB credentials
POSTGRES_DB_USER=
POSTGRES_DB_PASSWORD=

# alertservice SMTP credentials
ALERTSERVICE_SMTP_USER=
ALERTSERVICE_SMTP_PASSWORD=
ALERTSERVICE_SMTP_HOST=
ALERTSERVICE_SMTP_PORT=
ALERTSERVICE_SMTP_USE_TLS=
ALERTSERVICE_EMAIL_FROM=
ALERTSERVICE_EMAIL_TO=

# GTFS credentials
GTFS_LOGIN=
GTFS_PASSWORD=

# extractloadlivedata credentials
EXTRACTLOADLIVEDATA_TOKEN=
EXTRACTLOADLIVEDATA_ACCESS_KEY="${MINIO_PLATFORM_ACCESS_KEY}"
EXTRACTLOADLIVEDATA_SECRET_KEY="${MINIO_PLATFORM_SECRET_KEY}"
