{
  "expectation_suite_name": "transformlivedata",
  "meta": {
    "great_expectations_version": "0.17.0",
    "description": "Validation rules for TRANSFORMED output data (post-transformation via DataFrame)\nRaw validation is handled separately via raw_expectations.json with Pydantic"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_columns_to_match_set",
      "kwargs": {
        "column_set": [
          "extracao_ts", "veiculo_id", "linha_lt", "linha_code", "linha_sentido",
          "lt_destino", "lt_origem", "veiculo_prefixo", "veiculo_acessivel",
          "veiculo_ts", "veiculo_lat", "veiculo_long", "is_circular",
          "first_stop_id", "first_stop_lat", "first_stop_lon",
          "last_stop_id", "last_stop_lat", "last_stop_lon",
          "distance_to_first_stop", "distance_to_last_stop"
        ]
      },
      "meta": {
        "rule_type": "output_columns_exist",
        "description": "Validate all required output columns exist in transformed data",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "veiculo_id",
        "type_": "int"
      },
      "meta": {
        "rule_type": "column_data_types",
        "description": "Vehicle ID must be integer type",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "linha_code",
        "type_": "int"
      },
      "meta": {
        "rule_type": "column_data_types",
        "description": "Line code must be integer type",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "linha_sentido",
        "type_": "int"
      },
      "meta": {
        "rule_type": "column_data_types",
        "description": "Direction must be integer type (0=outbound, 1=return)",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "veiculo_lat",
        "type_": "float"
      },
      "meta": {
        "rule_type": "column_data_types",
        "description": "Latitude must be float type",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_of_type",
      "kwargs": {
        "column": "veiculo_long",
        "type_": "float"
      },
      "meta": {
        "rule_type": "column_data_types",
        "description": "Longitude must be float type",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "veiculo_id"
      },
      "meta": {
        "rule_type": "vehicle_ids_not_null",
        "description": "Vehicle ID is never null (required field)",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "distance_to_first_stop",
        "min_value": 0
      },
      "meta": {
        "rule_type": "distances_non_negative",
        "description": "Distance to first stop is non-negative (Haversine result)",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "distance_to_last_stop",
        "min_value": 0
      },
      "meta": {
        "rule_type": "distances_non_negative",
        "description": "Distance to last stop is non-negative (Haversine result)",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "veiculo_lat",
        "min_value": {"$PARAMETER": "lat_min_value"},
        "max_value": {"$PARAMETER": "lat_max_value"}
      },
      "meta": {
        "rule_type": "coordinates_in_rmsp",
        "description": "Latitude within RMSP (São Paulo metro) bounds with tolerance",
        "phase": "transformed"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "veiculo_long",
        "min_value": {"$PARAMETER": "long_min_value"},
        "max_value": {"$PARAMETER": "long_max_value"}
      },
      "meta": {
        "rule_type": "coordinates_in_rmsp",
        "description": "Longitude within RMSP (São Paulo metro) bounds with tolerance",
        "phase": "transformed"
      }
    }
  ]
}
