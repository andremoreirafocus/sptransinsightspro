{
  "version": 1.0,
  "pipeline": "transformlivedata",
  "source": "sptrans_api",
  "target_format": "parquet",
  "expectations": {
    "raw_positions_structure": {
      "enabled": true,
      "type": "input_structure",
      "description": "Validate raw API response has expected structure",
      "required_keys": ["metadata", "payload"],
      "payload_required_keys": ["l"]
    },
    "vehicle_fields": {
      "enabled": true,
      "type": "input_structure",
      "description": "Validate each vehicle record has required fields",
      "required_fields": ["p", "c", "py", "px", "ta"]
    },
    "output_columns_exist": {
      "enabled": true,
      "type": "schema",
      "description": "Validate all required columns exist in output",
      "source": "lineage"
    },
    "column_data_types": {
      "enabled": true,
      "type": "schema",
      "description": "Validate output columns have correct data types",
      "expectations": {
        "veiculo_id": "int",
        "veiculo_lat": "float",
        "veiculo_long": "float",
        "distance_to_first_stop": "float",
        "distance_to_last_stop": "float"
      }
    },
    "vehicle_ids_not_null": {
      "enabled": true,
      "type": "data_quality",
      "column": "veiculo_id",
      "description": "Validate vehicle_id is never null",
      "rule": "not_null"
    },
    "coordinates_in_rmsp": {
      "enabled": true,
      "type": "data_quality",
      "columns": {
        "latitude": "veiculo_lat",
        "longitude": "veiculo_long"
      },
      "description": "Validate coordinates are within RMSP with tolerance",
      "rule": "geographic_bounds",
      "bounds": {
        "latitude_min_strict": -23.911334,
        "latitude_max_strict": -23.194743,
        "longitude_min_strict": -46.984037,
        "longitude_max_strict": -46.184930,
        "tolerance_km": 0.5
      }
    },
    "distances_non_negative": {
      "enabled": true,
      "type": "data_quality",
      "columns": ["distance_to_first_stop", "distance_to_last_stop"],
      "description": "Validate distance calculations are non-negative",
      "rule": "non_negative"
    }
  },
  "columns": {
    "extracao_ts": {
      "input_sources": ["metadata.extracted_at"],
      "transformation": "parse ISO timestamp from metadata"
    },
    "veiculo_id": {
      "input_sources": ["payload.l[i].p"],
      "transformation": "cast vehicle ID from API payload",
      "data_type": "int",
      "description": "Unique vehicle identifier"
    },
    "linha_lt": {
      "input_sources": ["payload.l[i].c"],
      "transformation": "extract line identifier (linha)",
      "data_type": "string",
      "description": "Line code/identifier"
    },
    "linha_code": {
      "input_sources": ["payload.l[i].cl"],
      "transformation": "extract line code",
      "data_type": "int",
      "description": "Numeric line code"
    },
    "linha_sentido": {
      "input_sources": ["payload.l[i].sl"],
      "transformation": "extract direction (sentido)",
      "data_type": "int",
      "description": "Direction/sense of the line (0=outbound, 1=return)"
    },
    "lt_destino": {
      "input_sources": ["payload.l[i].lt0"],
      "transformation": "extract destination (lt0)",
      "data_type": "string",
      "description": "Line destination"
    },
    "lt_origem": {
      "input_sources": ["payload.l[i].lt1"],
      "transformation": "extract origin (lt1)",
      "data_type": "string",
      "description": "Line origin"
    },
    "veiculo_prefixo": {
      "input_sources": ["payload.l[i].p"],
      "transformation": "vehicle prefix (same as veiculo_id)",
      "data_type": "int",
      "description": "Vehicle prefix/number"
    },
    "veiculo_acessivel": {
      "input_sources": ["payload.l[i].a"],
      "transformation": "cast accessibility flag from payload",
      "data_type": "boolean",
      "description": "Vehicle accessible to wheelchair users"
    },
    "veiculo_ts": {
      "input_sources": ["payload.l[i].ta"],
      "transformation": "parse ISO timestamp from vehicle data",
      "data_type": "timestamp",
      "description": "Timestamp of vehicle position measurement"
    },
    "veiculo_lat": {
      "input_sources": ["payload.l[i].py"],
      "transformation": "cast latitude from API payload",
      "data_type": "float",
      "description": "Vehicle latitude coordinate",
      "validation_rule": "RMSP_LATITUDE_MIN to RMSP_LATITUDE_MAX with tolerance"
    },
    "veiculo_long": {
      "input_sources": ["payload.l[i].px"],
      "transformation": "cast longitude from API payload",
      "data_type": "float",
      "description": "Vehicle longitude coordinate",
      "validation_rule": "RMSP_LONGITUDE_MIN to RMSP_LONGITUDE_MAX with tolerance"
    },
    "is_circular": {
      "input_sources": ["trip_details.is_circular"],
      "transformation": "enrich with trip geometry (join on trip_id)",
      "data_type": "boolean",
      "description": "Whether trip is circular route"
    },
    "first_stop_id": {
      "input_sources": ["trip_details.first_stop_id"],
      "transformation": "enrich with trip details",
      "data_type": "string",
      "description": "ID of first stop on trip"
    },
    "first_stop_lat": {
      "input_sources": ["trip_details.first_stop_lat"],
      "transformation": "enrich with trip first stop location",
      "data_type": "float",
      "description": "Latitude of first stop"
    },
    "first_stop_lon": {
      "input_sources": ["trip_details.first_stop_lon"],
      "transformation": "enrich with trip first stop location",
      "data_type": "float",
      "description": "Longitude of first stop"
    },
    "last_stop_id": {
      "input_sources": ["trip_details.last_stop_id"],
      "transformation": "enrich with trip details",
      "data_type": "string",
      "description": "ID of last stop on trip"
    },
    "last_stop_lat": {
      "input_sources": ["trip_details.last_stop_lat"],
      "transformation": "enrich with trip last stop location",
      "data_type": "float",
      "description": "Latitude of last stop"
    },
    "last_stop_lon": {
      "input_sources": ["trip_details.last_stop_lon"],
      "transformation": "enrich with trip last stop location",
      "data_type": "float",
      "description": "Longitude of last stop"
    },
    "distance_to_first_stop": {
      "input_sources": ["veiculo_lat", "veiculo_long", "first_stop_lat", "first_stop_lon"],
      "transformation": "haversine distance calculation (meters)",
      "data_type": "float",
      "description": "Distance in meters from vehicle position to first stop",
      "validation_rule": "must be non-negative"
    },
    "distance_to_last_stop": {
      "input_sources": ["veiculo_lat", "veiculo_long", "last_stop_lat", "last_stop_lon"],
      "transformation": "haversine distance calculation (meters)",
      "data_type": "float",
      "description": "Distance in meters from vehicle position to last stop",
      "validation_rule": "must be non-negative"
    }
  }
}
