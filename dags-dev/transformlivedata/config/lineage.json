{
  "job_name": "transformlivedata_transform_positions",
  "job_owner": "data-engineering",
  "job_description": "Transform raw bus position API responses into structured DataFrame with vehicle locations, routes, and trip details",
  "columns": {
    "extracao_ts": {
      "input_sources": ["raw.metadata.extracted_at"],
      "transformation": "CAST(extracted_at AS TIMESTAMP)",
      "description": "Extraction timestamp from API response metadata"
    },
    "veiculo_id": {
      "input_sources": ["raw.payload.l[i].vs[j].p"],
      "transformation": "CAST(vehicle.p AS INTEGER)",
      "description": "Vehicle ID (prefix number)"
    },
    "linha_lt": {
      "input_sources": ["raw.payload.l[i].c"],
      "transformation": "Extract line identifier",
      "description": "Line identifier (route code)"
    },
    "linha_code": {
      "input_sources": ["raw.payload.l[i].cl"],
      "transformation": "CAST(line.cl AS INTEGER)",
      "description": "Line code (integer identifier)"
    },
    "linha_sentido": {
      "input_sources": ["raw.payload.l[i].sl"],
      "transformation": "CAST(direction AS INTEGER)",
      "description": "Direction/Sentido (0=outbound, 1=return)"
    },
    "lt_destino": {
      "input_sources": ["raw.payload.l[i].lt0"],
      "transformation": "Extract destination from line info",
      "description": "Route destination (terminal or endpoint)"
    },
    "lt_origem": {
      "input_sources": ["raw.payload.l[i].lt1"],
      "transformation": "Extract origin from line info",
      "description": "Route origin (starting point)"
    },
    "veiculo_prefixo": {
      "input_sources": ["raw.payload.l[i].vs[j].p"],
      "transformation": "Same as veiculo_id",
      "description": "Vehicle prefix (same as vehicle ID)"
    },
    "veiculo_acessivel": {
      "input_sources": ["raw.payload.l[i].vs[j].a"],
      "transformation": "CAST(accessibility_flag AS BOOLEAN)",
      "description": "Accessibility flag (wheelchair accessible)"
    },
    "veiculo_ts": {
      "input_sources": ["raw.payload.l[i].vs[j].ta"],
      "transformation": "CAST(vehicle_timestamp AS TIMESTAMP)",
      "description": "Vehicle position timestamp"
    },
    "veiculo_lat": {
      "input_sources": ["raw.payload.l[i].vs[j].py"],
      "transformation": "CAST(latitude AS FLOAT)",
      "description": "Vehicle latitude coordinate"
    },
    "veiculo_long": {
      "input_sources": ["raw.payload.l[i].vs[j].px"],
      "transformation": "CAST(longitude AS FLOAT)",
      "description": "Vehicle longitude coordinate"
    },
    "is_circular": {
      "input_sources": ["trip_details.is_circular"],
      "transformation": "LEFT JOIN trip_details ON trip_id = trip_details.trip_id",
      "description": "Whether route is circular (no distinct start/end)"
    },
    "first_stop_id": {
      "input_sources": ["trip_details.first_stop_id"],
      "transformation": "LEFT JOIN trip_details",
      "description": "GTFS stop ID of first stop in trip"
    },
    "first_stop_lat": {
      "input_sources": ["trip_details.first_stop_lat"],
      "transformation": "LEFT JOIN trip_details",
      "description": "Latitude of first stop"
    },
    "first_stop_lon": {
      "input_sources": ["trip_details.first_stop_lon"],
      "transformation": "LEFT JOIN trip_details",
      "description": "Longitude of first stop"
    },
    "last_stop_id": {
      "input_sources": ["trip_details.last_stop_id"],
      "transformation": "LEFT JOIN trip_details",
      "description": "GTFS stop ID of last stop in trip"
    },
    "last_stop_lat": {
      "input_sources": ["trip_details.last_stop_lat"],
      "transformation": "LEFT JOIN trip_details",
      "description": "Latitude of last stop"
    },
    "last_stop_lon": {
      "input_sources": ["trip_details.last_stop_lon"],
      "transformation": "LEFT JOIN trip_details",
      "description": "Longitude of last stop"
    },
    "distance_to_first_stop": {
      "input_sources": ["veiculo_lat", "veiculo_long", "first_stop_lat", "first_stop_lon"],
      "transformation": "HAVERSINE(veiculo_lat, veiculo_long, first_stop_lat, first_stop_lon) → km",
      "description": "Distance from vehicle to first stop (Haversine formula)"
    },
    "distance_to_last_stop": {
      "input_sources": ["veiculo_lat", "veiculo_long", "last_stop_lat", "last_stop_lon"],
      "transformation": "HAVERSINE(veiculo_lat, veiculo_long, last_stop_lat, last_stop_lon) → km",
      "description": "Distance from vehicle to last stop (Haversine formula)"
    }
  },
  "lineage_notes": "Raw bus positions API → Enrich with trip details → Calculate distances → Transform to output columns. All transformations are deterministic and reversible."
}
